{
  "name": "musmem-mag-parser",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "keywords": [],
  "author": "",
  "license": "proprietary",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "build": "tsc",
    "watch-ts": "tsc -w",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "bundle": "esbuild src/index.ts --bundle --platform=node --outfile=dist/bundle.js",
    "bundle-old": "esbuild src/index.ts --bundle --platform=node --outfile=dist/bundle.js --external:express --external:cors --external:helmet --external:dotenv --external:winston --external:@aws-sdk/* --external:express-rate-limit --external:@xmldom/xmldom --external:fs --external:path --external:http --external:https --external:url --external:querystring --external:stream --external:util --external:buffer --external:events --external:crypto --external:os --external:zlib --external:net --external:tls --external:child_process --external:cluster --external:worker_threads --external:perf_hooks --external:async_hooks --external:inspector --external:vm --external:module --external:assert --external:constants --external:domain --external:punycode --external:string_decoder --external:tty --external:readline --external:repl --external:timers --external:process",
    "bundle-prod": "npm run bundle && npm install --production --prefix dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.839.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.39.1",
    "globals": "^16.1.0",
    "jest": "^30.0.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.32.0"
  }
}
